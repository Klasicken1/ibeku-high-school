Options -Indexes
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
</IfModule>
<IfModule mod_php.c>
  php_flag session.cookie_httponly on
  php_flag session.use_strict_mode on
</IfModule>